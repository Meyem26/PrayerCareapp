EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_LANDING_URL=https://yourdomain.com
EXPO_PUBLIC_WEB_APP_URL=https://app.yourdomain.com
EXPO_PUBLIC_BETA_MODE=true

# Landing site (website/ folder on Vercel):
# APP_URL=https://app.yourdomain.com
# SITE_URL=https://yourdomain.com
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Edge Function secrets (Supabase Dashboard → Edge Functions → Secrets):
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini  (optional)
#
# Optional — only if you add licensed translations via API.Bible later:
# API_BIBLE_KEY=your-api.bible-key
#
# fetch-scripture works without any secrets (uses free bible-api.com).
